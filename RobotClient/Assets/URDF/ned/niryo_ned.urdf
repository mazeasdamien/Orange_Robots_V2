  <!-- Simple probe cylinder: 1 cm diameter (radius 0.005 m), 10 cm length -->
  <!-- Attached to tool_link, rotated to protrude along the arm's approach axis. -->
  <link name="tool_cylinder">
    <visual>
      <!-- Center the cylinder at half its length along local Z (after joint rotation). -->
      <!-- Rotate 90deg around X so cylinder axis aligns with local Y (arm approach direction). -->
      <!-- Offset center 5cm along Y so the cylinder extends outward from the wrist. -->
      <origin xyz="0 -0.04 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.005" length="0.08"/>
      </geometry>
