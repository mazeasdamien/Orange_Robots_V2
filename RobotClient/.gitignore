# Combined .gitignore for Unity + .NET Projects
# Robot Orange: Unity simulation + Console controller
#
# Get latest Unity rules from: https://github.com/github/gitignore/blob/main/Unity.gitignore
# Get latest .NET rules from: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

#######################
# Unity Project Files #
#######################

.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Gradle cache directory
.gradle/

# Unity-generated solution and project files (root level only)
/*.csproj
/*.unityproj
/*.sln
*.tmp
*.userprefs
*.booproj
*.svd
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
/[Aa]ssets/[Ss]treamingAssets/relay_config.json
/[Aa]ssets/[Ss]treamingAssets/relay_config.json.meta

#######################
# .NET Project Files  #
#######################

# Build results for Robot_Orange-controller
Robot_Orange-controller/[Bb]in/
Robot_Orange-controller/[Oo]bj/
Robot_Orange-controller/[Dd]ebug/
Robot_Orange-controller/[Rr]elease/
Robot_Orange-controller/x64/
Robot_Orange-controller/x86/
Robot_Orange-controller/[Aa][Rr][Mm]/
Robot_Orange-controller/[Aa][Rr][Mm]64/
Robot_Orange-controller/bld/

# Visual Studio cache/options for .NET projects
Robot_Orange-controller/.vs/

# JetBrains Rider
Robot_Orange-controller/.idea/
Robot_Orange-controller/*.sln.iml

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# .NET Core build artifacts
Robot_Orange-controller/**/project.lock.json
Robot_Orange-controller/**/project.fragment.lock.json
Robot_Orange-controller/**/artifacts/

# NuGet Packages
*.nupkg
*.snupkg
Robot_Orange-controller/**/packages/*
!Robot_Orange-controller/**/packages/build/
*.nuget.props
*.nuget.targets

# Test results
Robot_Orange-controller/[Tt]est[Rr]esult*/
Robot_Orange-controller/[Bb]uild[Ll]og.*
# .NET specific
*.pidb
*.svclog
*.scc
*.mdb
*.pdb

#######################
# IDE & OS Files      #
#######################

# Visual Studio Code
.vscode/

# JetBrains IDEs
.idea/

# OS files
.DS_Store
Thumbs.db
*~

# Logs
*.log

# API Keys - Never commit actual keys
Assets/Scripts/apikeys.txt
Assets/Scripts/apikeys.txt.meta

Packages/com.xreal.xr.tar.gz

Packages/com.xreal.xr.tar.gz
